---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>BOBA TIDE 技術紀錄</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, "Noto Sans TC", system-ui, sans-serif;
        color: #172033;
        background: #f6f4ef;
      }
      body {
        margin: 0;
      }
      main {
        width: min(1040px, calc(100% - 40px));
        margin: 0 auto;
        padding: 56px 0 72px;
      }
      .hero {
        border-bottom: 1px solid #d8d3c8;
        padding-bottom: 32px;
      }
      .eyebrow {
        color: #77604b;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      h1 {
        max-width: 760px;
        margin: 12px 0;
        font-size: clamp(2rem, 5vw, 4.5rem);
        line-height: 0.98;
        letter-spacing: 0;
      }
      .lead {
        max-width: 720px;
        color: #566070;
        font-size: 1.1rem;
        line-height: 1.8;
      }
      .grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 24px;
        margin-top: 32px;
      }
      .post, .panel {
        background: #fffdf8;
        border: 1px solid #ddd6c9;
        border-radius: 8px;
        padding: 24px;
      }
      .post a {
        color: #172033;
        text-decoration: none;
      }
      .post h2 {
        margin: 0 0 10px;
        font-size: 1.55rem;
      }
      .post p, .panel li {
        color: #566070;
        line-height: 1.7;
      }
      .panel h2 {
        margin-top: 0;
        font-size: 1.15rem;
      }
      .panel ul {
        margin: 0;
        padding-left: 1.2rem;
      }
      @media (max-width: 760px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <section class="hero">
        <p class="eyebrow">AI coding agent portfolio</p>
        <h1>BOBA TIDE 技術紀錄</h1>
        <p class="lead">
          這裡不是作品集空話，而是記錄如何接手 repo、拆解備料需求、修改後台規則、驗證 LINE Flex mock，並用 MCP 與 GitHub Pages 完成可展示的交付。
        </p>
      </section>

      <section class="grid" aria-label="文章列表與交付檢查">
        <div>
          {posts.map((post) => (
            <article class="post">
              <a href={`${base}blog/${post.id}/`}>
                <p class="eyebrow">{post.data.date.toLocaleDateString('zh-TW')}</p>
                <h2>{post.data.title}</h2>
                <p>{post.data.summary}</p>
              </a>
            </article>
          ))}
        </div>
        <aside class="panel">
          <h2>文章必須回答</h2>
          <ul>
            <li>企業題目如何拆成資料、規則、畫面、驗收。</li>
            <li>哪些截圖能證明功能真的跑過。</li>
            <li>mock、token、API 邊界怎麼保護正式平台。</li>
            <li>下一步如果接真實企業資料，風險在哪裡。</li>
          </ul>
        </aside>
      </section>
    </main>
  </body>
</html>
